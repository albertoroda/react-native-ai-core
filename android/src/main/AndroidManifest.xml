<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Keeps the process alive while AI generation runs in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Needed to download model files from HuggingFace -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Needed to read model files from arbitrary paths on Android ≤ 12L (API 32).
         NOT required for models downloaded via downloadModel() — those go to
         getExternalFilesDir() which is always accessible without permission. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <application>
        <service
            android:name=".InferenceService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
